#!/bin/sh
# postinstall for the FerroGate MIA macOS package.
#
# Creates the runtime/log directories the launchd daemon expects. The daemon is
# intentionally left UNLOADED — the operator must configure /etc/ferrogate/mia.env
# and then `sudo launchctl load -w /Library/LaunchDaemons/com.ferrogate.mia.plist`.
set -eu

install -d -m 0750 /var/run/ferrogate
install -d -m 0750 /var/log/ferrogate

echo "FerroGate MIA installed."
echo "  1. Edit /etc/ferrogate/mia.env"
echo "  2. sudo launchctl load -w /Library/LaunchDaemons/com.ferrogate.mia.plist"

exit 0
