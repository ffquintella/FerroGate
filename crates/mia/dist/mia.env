# FerroGate Machine Identity Agent (MIA) configuration.
#
# This file is read by the systemd unit as an EnvironmentFile. MIA is
# configured entirely through environment variables; see docs/mia.md and the
# crate documentation for the full list and semantics. Uncomment and edit the
# values you need, then `systemctl restart mia`.

# Tracing verbosity (tracing EnvFilter syntax). Default: info.
#RUST_LOG=info

# --- Helper API (feature F08) -------------------------------------------------
# Path to the local helper-API Unix socket. Its presence ENABLES the helper
# API; if unset, MIA logs a banner and exits. systemd provisions /run/ferrogate.
#FERROGATE_HELPER_SOCKET=/run/ferrogate/mia.sock

# Octal mode for the helper socket. Default: 660.
#FERROGATE_HELPER_SOCKET_MODE=660

# --- Allowlist ----------------------------------------------------------------
# Signed CBOR allowlist of vetted local callers. Absent => deny every caller
# (fail closed).
#FERROGATE_ALLOWLIST=/etc/ferrogate/allowlist.cbor

# Trusted CMIS enrollment public key used to verify the allowlist. Required
# whenever FERROGATE_ALLOWLIST is set.
#FERROGATE_ALLOWLIST_KEY=/etc/ferrogate/allowlist.pub

# Maximum accepted allowlist age in seconds. Default: 86400.
#FERROGATE_ALLOWLIST_MAX_AGE_SECS=86400

# --- Attestation --------------------------------------------------------------
# Override the IMA runtime-measurement log path.
#FERROGATE_IMA_LOG=/sys/kernel/security/integrity/ima/ascii_runtime_measurements
