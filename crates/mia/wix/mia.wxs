<?xml version="1.0" encoding="utf-8"?>
<!--
  WiX source (msitools/wixl dialect) for the FerroGate Machine Identity Agent
  (MIA) Windows MSI.

  Built on Linux (no Windows host required) by scripts/build-msi-amd64.sh with
  msitools' wixl. The Version and BinDir preprocessor variables are supplied on
  the wixl command line (see that script).

  Scope of the MSI: install mia.exe under "Program Files\FerroGate\MIA" and
  register + start the mia Windows service. The service is declared natively via
  ServiceInstall/ServiceControl so Windows Installer sequences install/start on
  install and stop/remove on uninstall (wixl mis-sequences custom actions). The
  ServiceInstall mirrors exactly what `mia service install` registers (see
  ferro-winauth::service): service name "mia", LocalSystem, auto-start, binpath
  `"<exe>" service run`.

  Two things the legacy NSIS installer also did — appending to the system PATH
  and creating the FerroGateClients helper group — are NOT done here: wixl
  supports neither the Environment element nor arbitrary-command custom actions.
  They are handled by the Chocolatey/NuGet wrapper (crates/mia/nuget/), which is
  the recommended install path and configures both before invoking this MSI. A
  bare-MSI install therefore yields the binary + service; an administrator must
  create the FerroGateClients local group (see `mia test`) for the helper pipe.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Id="*"
           Name="FerroGate Machine Identity Agent"
           Language="1033"
           Version="$(var.Version)"
           Manufacturer="FerroGate contributors"
           UpgradeCode="6F9B1F2E-1C3A-4E84-9A2D-2B7E5C0A1D44">

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="FerroGate Machine Identity Agent installer"
             Comments="https://github.com/ffquintella/FerroGate" />

    <!-- Replace any previously installed version on upgrade. -->
    <Upgrade Id="6F9B1F2E-1C3A-4E84-9A2D-2B7E5C0A1D44">
      <UpgradeVersion Minimum="0.0.0" IncludeMinimum="yes"
                      OnlyDetect="no" Property="OLDERVERSIONFOUND" />
    </Upgrade>

    <Media Id="1" Cabinet="product.cab" EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="FerroGateDir" Name="FerroGate">
          <Directory Id="INSTALLDIR" Name="MIA" />
        </Directory>
      </Directory>
    </Directory>

    <DirectoryRef Id="INSTALLDIR">
      <Component Id="MiaExe" Guid="2C8E0A11-94B6-4D7C-8B0E-7B0F4A9C2E01">
        <File Id="miaExe" Name="mia.exe" Source="$(var.BinDir)/mia.exe" KeyPath="yes" />

        <!-- Register the service exactly as `mia service install` does: name
             "mia", auto-start, LocalSystem, binpath `"<exe>" service run`. -->
        <ServiceInstall Id="MiaService"
                        Name="mia"
                        DisplayName="FerroGate Machine Identity Agent"
                        Description="Attests this host to CMIS and serves the local helper API for minting child tokens."
                        Type="ownProcess"
                        Start="auto"
                        ErrorControl="normal"
                        Account="LocalSystem"
                        Arguments="service run"
                        Vital="no" />
        <!-- Start on install; stop on install+uninstall; remove on uninstall.
             Windows Installer sequences these (StartServices / StopServices /
             DeleteServices) correctly around RemoveFiles. -->
        <ServiceControl Id="MiaServiceControl"
                        Name="mia"
                        Start="install"
                        Stop="both"
                        Remove="uninstall"
                        Wait="no" />
      </Component>
    </DirectoryRef>

    <Feature Id="Main" Title="FerroGate MIA" Level="1">
      <ComponentRef Id="MiaExe" />
    </Feature>
  </Product>
</Wix>
