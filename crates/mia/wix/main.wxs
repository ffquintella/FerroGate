<?xml version="1.0" encoding="windows-1252"?>
<!--
  WiX source for the FerroGate Machine Identity Agent (MIA) MSI installer.

  Built with cargo-wix (`make pkg-msi`, which runs `cargo wix -p mia`). cargo-wix
  supplies these preprocessor variables at build time:
    $(var.Version)            - crate version from Cargo.toml
    $(var.Platform)           - x64 / x86
    $(var.CargoTargetBinDir)  - directory holding the built mia.exe

  The installer drops mia.exe under "Program Files\FerroGate\MIA" and adds that
  directory to the system PATH. MIA is configured via environment variables (see
  docs/mia.md); on Windows the helper API is exposed over a named pipe.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product
        Id="*"
        Name="FerroGate Machine Identity Agent"
        UpgradeCode="8C3A3E05-30AF-478F-908C-709707046EA2"
        Manufacturer="FerroGate contributors"
        Language="1033"
        Codepage="1252"
        Version="$(var.Version)">

        <Package Id="*"
            Keywords="Installer"
            Description="FerroGate Machine Identity Agent (MIA)"
            Manufacturer="FerroGate contributors"
            InstallerVersion="450"
            Languages="1033"
            Compressed="yes"
            InstallScope="perMachine"
            SummaryCodepage="1252"/>

        <MajorUpgrade
            Schedule="afterInstallInitialize"
            DowngradeErrorMessage="A newer version of FerroGate MIA is already installed. Setup will now exit."/>

        <Media Id="1" Cabinet="media1.cab" EmbedCab="yes" DiskPrompt="CD-ROM #1"/>
        <Property Id="DiskPrompt" Value="FerroGate MIA Installation"/>

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFiles64Folder" Name="PFiles">
                <Directory Id="FerroGateFolder" Name="FerroGate">
                    <Directory Id="APPLICATIONFOLDER" Name="MIA">

                        <!-- The agent binary. -->
                        <Component Id="binMia" Guid="*">
                            <File
                                Id="miaExe"
                                Name="mia.exe"
                                DiskId="1"
                                Source="$(var.CargoTargetBinDir)\mia.exe"
                                KeyPath="yes"/>
                        </Component>

                        <!-- Prepend the install dir to the system PATH. -->
                        <Component Id="binPath" Guid="1871F463-A4E9-4D6F-903D-C643842B9E69" KeyPath="yes">
                            <Environment
                                Id="PATH"
                                Name="PATH"
                                Value="[APPLICATIONFOLDER]"
                                Permanent="no"
                                Part="last"
                                Action="set"
                                System="yes"/>
                        </Component>
                    </Directory>
                </Directory>
            </Directory>
        </Directory>

        <Feature
            Id="Binaries"
            Title="FerroGate MIA"
            Description="Installs the Machine Identity Agent and adds it to the system PATH."
            Level="1"
            ConfigurableDirectory="APPLICATIONFOLDER"
            AllowAdvertise="no"
            Display="expand"
            Absent="disallow">
            <ComponentRef Id="binMia"/>
            <ComponentRef Id="binPath"/>
        </Feature>

        <Property Id="ARPHELPLINK" Value="https://github.com/ffquintella/FerroGate"/>

        <UIRef Id="WixUI_FeatureTree"/>
    </Product>
</Wix>
